      m_Items: []
  - m_Id: 83012305763328000
    m_Localized: "<line-height=15><color=#FFFF00><size=20>\u041B\u0430\u0433\u0445\u043E\u043B\u044C\u043C</size>\\r\n<size=12><i>-
      \u042D\u043A\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u0447\u0438\u0441\u0442\u043E\u0435
      \u0441\u0435\u0440\u0434\u0446\u0435\\r\n</i></size></color></line-height>\\r\n<line-height=10>\u041D\u0435\u0431\u043E\u043B\u044C\u0448\u0430\u044F
      \u0434\u0435\u0440\u0435\u0432\u0443\u0448\u043A\u0430 \u043D\u0430\n\u0441\u0435\u0432\u0435\u0440\u043E-\u0437\u0430\u043F\u0430\u0434\u0435,\n\u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u0443\u044E\u0449\u0430\u044F\u0441\u044F
      \u043D\u0430\n\u0440\u044B\u0431\u043D\u043E\u0439 \u0438 \u0437\u0435\u0440\u043D\u043E\u0432\u043E\u0439\n\u043E\u0442\u0440\u0430\u0441\u043B\u044F\u0445.\\n\n\u041E\u0441\u043D\u043E\u0432\u043D\u043E\u0439
      \u043F\u043E\u0441\u0442\u0430\u0432\u0449\u0438\u043A\n\u043F\u0438\u0449\u0435\u0432\u043E\u0433\u043E
      \u0441\u044B\u0440\u044C\u044F \u041E\u0441\u0442\u0432\u0430\u0439\u043D\u0430.</line-height>"
    m_Metadata:
      m_Items: []
  - m_Id: 83012677324136448
    m_Localized: "<line-height=15><color=#FFFF00><size=20>\u0414\u043E\u0431\u0440\u043E
      \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C!</size>\\r\n<size=12><i>-
      \u0412\u0430\u0448\u0435 \u0442\u0435\u043A\u0443\u0449\u0435\u0435 \u043C\u0435\u0441\u0442\u043E\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435:
      \u043F\u043E\u043B\u0443\u043E\u0441\u0442\u0440\u043E\u0432 \u0422\u0435\u0440\u0440\u0430\u043C\u0438\u043B\u043B\u044C\\r\n</i></size></color></line-height>\\r\n\u041D\u0430\u0437\u0432\u0430\u043D
      \u0432 \u0447\u0435\u0441\u0442\u044C \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
      \u0431\u043E\u0440\u0446\u0430 \u043F\u0440\u0430\u0432\u043E\u0441 \u0422\u044D\u044F
      \u041C\u0438\u043B\u043B\u044F, \u043F\u0435\u0440\u0432\u043E\u0433\u043E
      \u0433\u0443\u0431\u0435\u0440\u043D\u0430\u0442\u043E\u0440\u0430 \u044D\u0442\u043E\u0433\u043E
      \u043A\u0440\u0430\u044F, \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u043E\u0433\u043E
      94 \u0433\u043E\u0434\u0430 \u043D\u0430\u0437\u0430\u0434 (20\u0425\u0425).\\n\u041D\u0430\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u0435\u0442
      5 \u0433\u043E\u0440\u043E\u0434\u043E\u0432. \u0412\u0431\u043B\u0438\u0437\u0438
      \u043C\u0430\u0442\u0435\u0440\u0438\u043A\u0430 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
      \u043E\u0441\u0442\u0440\u043E\u0432 \u2013 \u0413\u0430\u0440\u0434\u0435\u043D-\u0420\u043E\u043A
      \u2013 \u0438\u043C\u0435\u044E\u0449\u0438\u0439 \u0441\u043A\u0430\u043B\u0438\u0441\u0442\u0443\u044E
      \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0443 \u0438 \u0431\u043E\u0433\u0430\u0442\u044B\u0439
      \u0440\u0430\u0437\u043D\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u044B\u043C\u0438
      \u043F\u043E\u043B\u0435\u0437\u043D\u044B\u043C\u0438 \u0438\u0441\u043A\u043E\u043F\u0430\u0435\u043C\u044B\u043C\u0438.
      \u0414\u0430\u043D\u043D\u044B\u0439 \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0439
      \u0440\u0435\u0433\u0438\u043E\u043D \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
      \u0441\u0432\u043E\u0438\u043C\u0438 \u043C\u0435\u0442\u0430\u043B\u043B\u0443\u0440\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
      \u0438\u0437\u0434\u0435\u043B\u0438\u044F\u043C\u0438 \u043D\u0430 \u0432\u0441\u0451
      \u041D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435."
    m_Metadata:
      m_Items: []
