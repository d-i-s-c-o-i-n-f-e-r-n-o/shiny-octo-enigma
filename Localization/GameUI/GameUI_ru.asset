      3 \u0434\u043D\u044F\\r\n</i></size></color></line-height>\\r\n<line-height=10>\u042E\u0433\u043E-\u0432\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u0439
      \u0440\u0430\u0431\u043E\u0447\u0438\u0439\n\u043F\u0443\u043D\u043A\u0442
      \u043D\u0430 \u043E\u0441\u0442\u0440\u043E\u0432\u0435\n\u0413\u0430\u0440\u0434\u0435\u043D-\u0420\u043E\u043A.
      \u0412 \u043F\u0440\u0435\u0434\u0433\u043E\u0440\u044C\u0435\n\u0440\u0430\u0441\u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0442\u0441\u044F
      \u043A\u0440\u0443\u043F\u043D\u044B\u0435\n\u0448\u0430\u0445\u0442\u044B
      \u0432\u0431\u043B\u0438\u0437\u0438\n\u043C\u0435\u0441\u0442\u043E\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0439
      \u0447\u0435\u0440\u043D\u044B\u0445 \u0438\n\u0446\u0432\u0435\u0442\u043D\u044B\u0445
      \u043C\u0435\u0442\u0430\u043B\u043B\u043E\u0432.\\n\n\u0413\u043B\u0430\u0432\u043D\u044B\u0439
      \u043F\u043E\u0441\u0442\u0430\u0432\u0449\u0438\u043A \u0441\u044B\u0440\u044C\u044F\n\u0434\u043B\u044F
      \u0437\u0430\u0432\u043E\u0434\u043E\u0432 \u0412\u0438\u0432\u0435\u0441\u0442\u043E\u043D\u0430.</line-height>"
    m_Metadata:
