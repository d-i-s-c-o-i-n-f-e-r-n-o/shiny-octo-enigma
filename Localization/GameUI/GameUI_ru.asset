  - m_Id: 83008206422564864
    m_Localized: "<line-height=15><color=#FFFF00><size=20>\u041E\u0441\u0442\u0432\u0430\u0439\u043D</size>\\r\n<size=12><i>-
      \u0412\u0441\u0435 \u0434\u043E\u0440\u043E\u0433\u0438 \u0432\u0435\u0434\u0443\u0442
      \u0441\u044E\u0434\u0430\\r\n</i></size></color></line-height>\\r\n<line-height=10>\u0421\u0442\u043E\u043B\u0438\u0446\u0430
      \u043F\u043E\u043B\u0443\u043E\u0441\u0442\u0440\u043E\u0432\u0430.\\n\n\u041A\u0440\u0443\u043F\u043D\u044B\u0439
      \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439\n\u0446\u0435\u043D\u0442\u0440,
      \u044F\u0432\u043B\u044F\u044E\u0449\u0438\u0439\u0441\u044F \u0441\u0430\u043C\u044B\u043C\n\u0433\u0443\u0441\u0442\u043E\u043D\u0430\u0441\u0435\u043B\u0435\u043D\u043D\u044B\u043C
      \u0433\u043E\u0440\u043E\u0434\u043E\u043C\n\u0440\u0435\u0433\u0438\u043E\u043D\u0430.</line-height>"
    m_Metadata:
      m_Items: []
  - m_Id: 83010599885365248
    m_Localized: "<line-height=15><color=#FFFF00><size=20>\u0412\u0430\u0442\u0435\u0440\u043A\u043E\u043B\u043B</size>\\r\n<size=12><i>-
      \u0413\u043E\u0440\u043E\u0434, \u0447\u0442\u043E \u043D\u0438\u043A\u043E\u0433\u0434\u0430
      \u043D\u0435 \u0441\u043F\u0438\u0442\\r\n</i></size></color></line-height>\\r\n<line-height=10>\u041A\u0440\u0443\u043F\u043D\u044B\u0439
      \u0442\u043E\u0440\u0433\u043E\u0432\u044B\u0439 \u043F\u043E\u0440\u0442 \u043D\u0430\n\u0432\u043E\u0441\u0442\u043E\u043A\u0435
      \u043F\u043E\u043B\u0443\u043E\u0441\u0442\u0440\u043E\u0432\u0430.\\n\n\u0417\u0434\u0435\u0441\u044C
      \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435\n\u043F\u0440\u0435\u0434\u043F\u0440\u0438\u044F\u0442\u0438\u044F
      \u0441\u0431\u044B\u0432\u0430\u044E\u0442 \u0441\u0432\u043E\u0439\n\u0442\u043E\u0432\u0430\u0440
      \u043D\u0430 \u043C\u0430\u0442\u0435\u0440\u0438\u043A \u0438\n(\u0441 \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u044F
      \u0421\u043E\u041F\u0440\u041E)\n\u0432 \u0434\u0440\u0443\u0433\u0438\u0435
      \u0438\u0437\u043E\u043B\u044B.</line-height>"
    m_Metadata:
      m_Items: []
  - m_Id: 83011286392266752
    m_Localized: "<line-height=15><color=#FFFF00><size=20>\u0412\u0438\u0432\u0435\u0441\u0442\u043E\u043D</size>\\r\n<size=12><i>-
      \u041C\u0435\u0442\u0430\u043B\u043B\u0443\u0440\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
      \u0440\u0430\u0439\\r\n</i></size></color></line-height>\\r\n<line-height=10>\u041F\u0440\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u044B\u0439
      \u0446\u0435\u043D\u0442\u0440\n\u0440\u0435\u0433\u0438\u043E\u043D\u0430,
      \u043D\u0430\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u044E\u0449\u0438\u0439\n\u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u0430
      \u043E\u043A\u043E\u043B\u043E 50\n\u043A\u0440\u0443\u043F\u043D\u044B\u0445
      \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u044F\u0442\u0438\u0439,\n\u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u044E\u0449\u0438\u0445
      \u041D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435\n\u0432\u0441\u0435\u043C
      \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u044B\u043C \u043F\u043E\n\u0437\u0430\u043A\u0430\u0437\u0443
      \u0421\u043E\u041F\u0440\u041E.\n\u0413\u043E\u0442\u043E\u0432\u0430\u044F
      \u043F\u0440\u043E\u0434\u0443\u043A\u0446\u0438\u044F\n\u043F\u043E\u0441\u0442\u0443\u043F\u0430\u0435\u0442
      \u043D\u0430 \u043A\u043E\u0440\u0430\u0431\u043B\u044F\u0445\n\u0412\u0430\u0442\u0435\u0440\u043A\u043E\u043B\u043B\u0430
